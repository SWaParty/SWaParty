# SWaParty frontend and Cloudflare Pages Functions example.
# Copy the values into your local/deployment secret store. Do not commit real .env files.

# Frontend
VITE_REALTIME_WS_URL=wss://rt.example.com

# OAuth
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=CHANGE_ME_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=CHANGE_ME_GITHUB_CLIENT_SECRET
OAUTH_REDIRECT_BASE=https://example.com
OAUTH_STATE_SECRET=CHANGE_ME_LONG_RANDOM_STATE_SECRET

# Email
RESEND_API_KEY=CHANGE_ME_RESEND_API_KEY
RESEND_FROM=SWaParty <no-reply@example.com>

# Multi-factor authentication
MFA_TOTP_SECRET_KEY=CHANGE_ME_LONG_RANDOM_MFA_SECRET

# Realtime WebSocket and publish bridge
REALTIME_WS_JWT_SECRET=CHANGE_ME_SAME_AS_REALTIME_VPS_JWT_SECRET
REALTIME_PUBLISH_URL=https://rt.example.com/publish
REALTIME_PUBLISH_TOKEN=CHANGE_ME_REALTIME_PUBLISH_TOKEN

# R2 S3 API for browser upload presigned URLs
MEDIA_PUBLIC_ORIGIN=https://media.example.com
AVATAR_PUBLIC_ORIGIN=https://avatars.example.com
R2_ACCESS_KEY_ID=CHANGE_ME_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=CHANGE_ME_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=CHANGE_ME_MEDIA_BUCKET
R2_ENDPOINT=https://CHANGE_ME_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_PRESIGN_EXPIRES_SEC=86400

# Spring room-state backend bridge
RMSTATE_BASE_URL=https://rmstate.example.com
RMSTATE_INTERNAL_API_TOKEN=CHANGE_ME_INTERNAL_TOKEN

# Invite expiration cron worker
CRON_TARGET_URL=https://example.com/api/cron/invites-expire
CRON_SECRET=CHANGE_ME_CRON_SECRET

# Cloudflare bindings configured in wrangler.toml, not as secrets:
# DB, AVATARS, MEDIA
